<?xml version="1.0" encoding="utf-8"?>
<resources>

    <declare-styleable name="RotateLoadingButton">
        <attr name="loadingColor" format="color"/>
        <attr name="finishBgColor" format="color"/>
        <attr name="errorBgColor" format="color"/>
        <attr name="normalTextColor" format="color"/>
        <attr name="normalText" format="string"/>
        <attr name="normalTextSize" format="dimension"/>
        <attr name="normalBgColor" format="color"/>
        <attr name="normalPressedColor" format="color"/>
        <attr name="cornerRadius" format="dimension"/>
        <attr name="disabledBgColor" format="color"/>
    </declare-styleable>

    <declare-styleable name="SmoothCheckBox">
        <attr name="duration" format="integer"/>
        <attr name="stroke_width" format="dimension"/>
        <attr name="color_tick" format="color"/>
        <attr name="color_checked" format="color"/>
        <attr name="color_unchecked" format="color"/>
        <attr name="color_unchecked_stroke" format="color"/>
        <attr name ="shape_type" format="enum">
            <enum name="circle" value="1"/>
            <enum name="rect" value="2"/>
        </attr>
    </declare-styleable>

</resources>